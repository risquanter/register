# Supply chain hardening — see ADR-020
# Prevent packages from running arbitrary code during install
ignore-scripts=true

# Pin exact versions to prevent silent upgrades
save-exact=true

# Do not auto-install required peerDependencies (npm v7+ default behaviour).
# Incident (2026-07-21): `geist` declares `next` as a *required* (non-optional)
# peerDependency; a plain `npm install` silently pulled in next@16.2.2 (high-
# severity CVEs: SSRF, auth bypass, cache poisoning — see ADR-020 §7) and its
# `sharp` dependency (~35 native binary packages), none of which are used by
# this app or declared in package.json. legacy-peer-deps reverts to npm v6
# behaviour: peers are reported, never silently installed.
legacy-peer-deps=true
engine-strict=true
