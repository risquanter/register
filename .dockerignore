# Security: Deny everything by default, allow only what's needed
*

# --------------------------------------------------------------------------
# Build essentials — shared by containers/prod/Dockerfile.register-prod
#                              and containers/prod/Dockerfile.frontend-prod
# --------------------------------------------------------------------------
!build.sbt
!project/
!modules/common/src/main/

# --------------------------------------------------------------------------
# Register server build sources — containers/prod/Dockerfile.register-prod
# --------------------------------------------------------------------------
!modules/server/src/main/

# --------------------------------------------------------------------------
# Frontend (SPA) build sources — containers/prod/Dockerfile.frontend-prod
# --------------------------------------------------------------------------
!modules/app/package.json
!modules/app/.npmrc
!modules/app/src/main/
!modules/app/styles/
!modules/app/index.html
!modules/app/main.js
!modules/app/vite.config.js

# Exclude nested build artifacts even from allowed dirs
project/target/
project/project/target/
target/
.bloop/
.bsp/
.metals/

# Security: Block sensitive files
.env
.env.*
*.key
*.pem
*.p12
*.jks
*.crt
secrets/

# Development artifacts
.git/
.idea/
.vscode/
*.iml
metals.sbt

# Documentation and tests
docs/
test/
*Spec.scala
*.md

# Temporary files
temp/
*.log
*.swp
*.swo
*~

# CI/CD and Docker
.github/
.gitlab-ci.yml
Dockerfile*
docker-compose*.yml
.dockerignore
