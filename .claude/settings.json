{
  "permissions": {
    "allow": [
      "Bash(sbt 'commonJVM/test; server/test; app/test')"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/protocol-gate.sh\"",
            "timeout": 10,
            "statusMessage": "Working-protocol gate"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/protocol-gate.sh\"",
            "timeout": 10,
            "statusMessage": "Working-protocol gate"
          }
        ]
      }
    ]
  }
}
