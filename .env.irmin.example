# Persistent local stack (Irmin risk-tree store + PostgreSQL workspace store).
# Copy to .env.irmin and pass with: docker compose --env-file .env.irmin ...
# Requires --profile persistence (starts the irmin and postgres containers).
#
# These override the in-memory defaults baked into docker-compose.yml. Values
# are picked up via ${VAR} interpolation in the register-server environment
# block — every var below must exist there to reach the container.

# Risk-tree persistence: content-addressed Irmin backend.
REGISTER_REPOSITORY_TYPE=irmin
IRMIN_URL=http://irmin:8080

# Workspace-metadata persistence: PostgreSQL (durable across restarts).
# Without this the workspace store stays in-memory and every workspace is lost
# on restart even though its trees are safe in Irmin. DB connection + Flyway
# migration use the REGISTER_DB_* / REGISTER_FLYWAY_URL defaults in compose,
# which already point at the postgres service.
REGISTER_WORKSPACE_STORE_BACKEND=postgres

# Workspace expiry: extend well past the 72h/1h defaults so a persistent stack
# does not reap workspaces during normal use. Set both to 0 to disable expiry
# entirely (enterprise no-op reaper).
REGISTER_WORKSPACE_TTL=120h
REGISTER_WORKSPACE_IDLE_TIMEOUT=120h
